PROJECT_NAME=Self-Checkout ML
ENVIRONMENT=local
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173

S3_ENDPOINT_URL=http://localhost:8082
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=dev-access-key
S3_SECRET_ACCESS_KEY=dev-secret-key
S3_SESSION_TOKEN=
S3_PUBLIC_BASE_URL=http://localhost:8082
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true
S3_VERIFY_TLS=true
S3_CONNECT_TIMEOUT=5
S3_READ_TIMEOUT=30
S3_MAX_RETRIES=3
S3_CREATE_BUCKETS=true
S3_SHELF_BUCKET=session-images
S3_SCALE_BUCKET=scale-images
S3_EXTERNAL_BUCKET=uploaded-images
S3_TRAINING_BUCKET=training-data
S3_LABEL_STUDIO_EXPORT_BUCKET=labelstudio-exports
MLFLOW_TRACKING_URI=http://127.0.0.1:5002
MLFLOW_EXPERIMENT_NAME=self-checkout-classifier
MLFLOW_REGISTERED_MODEL_NAME=self-checkout-classifier
MLFLOW_SHELF_EXPERIMENT_NAME=self-checkout-shelf-classifier
MLFLOW_SHELF_MODEL_NAME=self-checkout-shelf-classifier
MODEL_CACHE_DIR=.cache/model_store
BACKEND_URL=http://127.0.0.1:8000
LABEL_STUDIO_URL=http://127.0.0.1:8080
LABEL_STUDIO_API_KEY=
LABEL_STUDIO_SCALE_PROJECT_TITLE=scale-products
LABEL_STUDIO_SHELF_PROJECT_TITLE=shelf-products
LABEL_STUDIO_EXTERNAL_PROJECT_TITLE=external-products
